# ============================================================================
# Fake News Generator — environment variables
# ============================================================================
# Copy this file to `.env` and fill in the values you need.
# For Docker Compose, only OPENAI_API_KEY is required — the rest have sensible
# defaults wired up in docker-compose.yml.
# ============================================================================

# ---- LLM provider (REQUIRED) -----------------------------------------------
# API key for the LLM provider. Used by both the transformer and chat services.
OPENAI_API_KEY=sk-your-key-here

# Optional: custom base URL for OpenAI-compatible providers.
# Leave unset to use OpenAI directly. Set this to use OpenRouter, Groq, etc.
# OPENAI_BASE_URL=https://openrouter.ai/api/v1


# ---- Database (OPTIONAL for Docker, REQUIRED for local dev) ----------------
# PostgreSQL connection string. When running with `docker compose up`,
# this is injected automatically by docker-compose.yml and you can ignore it.
# Override only if you're running the backend locally without Docker,
# or if you want to point at an external Postgres instance.
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fakenews


# ---- Redis (OPTIONAL for Docker, REQUIRED for local dev) -------------------
# Redis is used by Celery as BOTH the message broker (to enqueue transform
# jobs) AND the result backend (to track task state). When running with
# `docker compose up`, this is injected automatically and you can ignore it.
# Override only for local dev without Docker.
# REDIS_URL=redis://localhost:6379/0
